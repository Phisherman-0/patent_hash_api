{
  "name": "patent-hash-backend",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development nodemon --exec 'tsx index.ts' --ext ts,json --ignore dist --ignore node_modules",
    "build": "tsc && esbuild index.ts --platform=node --bundle --format=esm --outdir=dist --external:bcrypt --external:bufferutil --external:utf-8-validate --external:cpu-features --external:ssh2",
    "start": "NODE_ENV=production node dist/index.js",
    "start:prod": "NODE_ENV=production node --env-file=.env.production dist/index.js",
    "check": "tsc",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "build:prod": "npm run check && npm run build"
  },
  "dependencies": {
    "@google/generative-ai": "^0.15.0",
    "@types/express-rate-limit": "^5.1.3",
    "axios": "^1.16.1",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.39.1",
    "drizzle-zod": "^0.7.0",
    "esbuild": "^0.25.0",
    "ethers": "^6.16.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "form-data": "^4.0.5",
    "jsonwebtoken": "^9.0.3",
    "memoizee": "^0.4.17",
    "memorystore": "^1.6.7",
    "multer": "^2.1.1",
    "mysql2": "^3.22.3",
    "nanoid": "^5.1.5",
    "nodemailer": "^7.0.12",
    "openai": "^5.12.2",
    "openid-client": "^6.6.4",
    "typescript": "5.6.3",
    "ws": "^8.18.0",
    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/memoizee": "^0.4.12",
    "@types/multer": "^2.1.0",
    "@types/nanoid": "^2.1.0",
    "@types/node": "^20.16.11",
    "@types/nodemailer": "^7.0.4",
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.30.4",
    "nodemon": "^3.1.10",
    "tsx": "^4.19.1"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8"
  }
}
