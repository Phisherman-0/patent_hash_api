{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowJs": true,
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../shared/*"],
      "drizzle-orm": ["./node_modules/drizzle-orm"],
      "drizzle-orm/mysql-core": ["./node_modules/drizzle-orm/mysql-core"],
      "drizzle-zod": ["./node_modules/drizzle-zod"],
      "zod": ["./node_modules/zod"]
    }
  },
  "include": [
    "server/**/*",
    "../shared/**/*",
    "*.ts",
    "services/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "drizzle.config.ts"
  ]
}